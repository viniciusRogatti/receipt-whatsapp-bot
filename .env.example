BOT_ENV=development
LOG_LEVEL=info
TEST_IMAGES_DIR=./test-images
OUTPUTS_DIR=./outputs
DEBUG_SESSIONS_DIR=./outputs/debug-sessions
DEBUG_SERVER_PORT=3388
RECEIPT_API_PORT=3390
RECEIPT_INGEST_TMP_DIR=./outputs/ingest-tmp
RECEIPT_STORAGE_DIR=./outputs/receipt-storage
RECEIPT_QUEUE_DIR=./outputs/receipt-queue
RECEIPT_WORKER_POLL_MS=1500
RECEIPT_ASYNC_WHATSAPP_MODE=false
RECEIPT_DEFAULT_COMPANY_ID=mar-e-rio
RECEIPT_DEFAULT_SOURCE_ID=api
RECEIPT_DEFAULT_DOCUMENT_TYPE=delivery_receipt
RECEIPT_COMPANY_INGEST_TOKENS={"mar-e-rio":["local-mar-e-rio-token"]}
RECEIPT_PROVIDER_GOOGLE_VISION_ENABLED=true
RECEIPT_PROVIDER_GOOGLE_VISION_ENDPOINT=https://vision.googleapis.com/v1/images:annotate
RECEIPT_PROVIDER_GOOGLE_VISION_API_KEY=
RECEIPT_PROVIDER_GOOGLE_VISION_BEARER_TOKEN=
RECEIPT_PROVIDER_GOOGLE_VISION_TIMEOUT_MS=20000
RECEIPT_PROVIDER_OPENAI_ENABLED=true
RECEIPT_PROVIDER_OPENAI_BASE_URL=https://api.openai.com/v1
RECEIPT_PROVIDER_OPENAI_API_KEY=
RECEIPT_PROVIDER_OPENAI_MODEL=gpt-4.1-mini
RECEIPT_PROVIDER_OPENAI_TIMEOUT_MS=25000
OCR_PROBE_ENABLED=true
OCR_PROBE_LANG=por
OCR_PROBE_VARIANT_LIMIT=4
OCR_FULL_LANG=por
OCR_REGION_LANG=por
OCR_LANG_PATH=.
OCR_FULL_VARIANT_LIMIT=1
OCR_FULL_MAX_EDGE=1100
OCR_REGION_MAX_EDGE=900
OCR_REGION_MIN_EDGE=1200
OCR_NF_EXPECTED_LENGTHS=7
OCR_SUPPRESS_CONSOLE_NOISE=true
RECEIPT_PROFILE_ID=mar_e_rio
RECEIPT_INVOICE_LOOKUP_MODE=auto
RECEIPT_INVOICE_LOOKUP_COMPANY_CODE=mar_e_rio
RECEIPT_INVOICE_LOOKUP_COMPANY_ID=
RECEIPT_INVOICE_LOOKUP_BACKEND_ENV_PATH=../../backend/.env
RECEIPT_LOCAL_FAST_MODE=true
RECEIPT_LOCAL_REPORT_ONLY=true
RECEIPT_LOCAL_MAX_IMAGES=0
