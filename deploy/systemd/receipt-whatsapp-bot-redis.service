[Unit]
Description=Redis for receipt-whatsapp-bot
After=network.target

[Service]
Type=notify
User=redis
Group=redis
ExecStart=/usr/bin/redis-server /etc/redis/receipt-whatsapp-bot.conf --supervised systemd --daemonize no
ExecStop=/usr/bin/redis-cli -p 6379 shutdown
Restart=always
RestartSec=3
TimeoutStartSec=30
TimeoutStopSec=30
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/var/lib/redis-receipt-whatsapp-bot

[Install]
WantedBy=multi-user.target
